---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TraceDivider from '../../components/TraceDivider.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

type Props = {
  post: CollectionEntry<'posts'>;
};

const { post } = Astro.props;
const { title, date, excerpt, category, github, demo_url, demo_video, technologies } =
  post.data;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(date);

const { Content } = await render(post);
---

<BaseLayout title={title} description={excerpt}>
  <article class="max-w-2xl mx-auto px-6 md:px-12 pt-32 pb-24">
    <a
      href="/"
      class="font-utility text-sm text-(--color-text-muted) hover:text-(--color-accent) transition-colors"
    >
      ← All posts
    </a>
    <h1 class="font-display font-bold text-(--text-h1) mt-6">
      {title}
    </h1>
    <div class="flex items-center gap-4 mt-4">
      <time class="font-utility text-sm text-(--color-text-muted)" datetime={date.toISOString()}>
        {formattedDate}
      </time>
      <span class="category-pill font-utility text-xs px-3 py-0.5 rounded-full border" data-category={category}>
        {category}
      </span>
    </div>
    {technologies && technologies.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-5">
        {technologies.map((tech) => (
          <span class="font-utility text-xs px-3 py-1 rounded-full bg-(--color-surface-hover) border border-(--color-border) text-(--color-text-muted)">
            {tech}
          </span>
        ))}
      </div>
    )}
    {(github || demo_url) && (
      <div class="flex flex-wrap items-center gap-4 mt-6 pb-6 border-b border-(--color-border)">
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="font-utility text-sm px-4 py-2 rounded-lg bg-(--color-accent)/10 text-(--color-accent) hover:bg-(--color-accent)/20 transition-colors"
          >
            View on GitHub ↗
          </a>
        )}
        {demo_url && (
          <a
            href={demo_url}
            target="_blank"
            rel="noopener noreferrer"
            class="font-utility text-sm px-4 py-2 rounded-lg bg-(--color-accent-green)/20 text-(--color-accent-green) hover:brightness-110 transition-all"
          >
            Live Demo ↗
          </a>
        )}
      </div>
    )}
    {demo_video && (
      <div class="mt-8">
        <video
          class="w-full aspect-video rounded-lg"
          controls
          autoplay
          muted
          loop
          playsinline
        >
          <source src={demo_video} type="video/mp4" />
        </video>
      </div>
    )}
    <div class="prose mt-8">
      <Content />
    </div>
    <TraceDivider />
  </article>
</BaseLayout>

<style>
  .category-pill[data-category="robotics"] {
    background-color: color-mix(in srgb, var(--color-accent-green) 20%, transparent);
    color: var(--color-accent-green);
    border-color: color-mix(in srgb, var(--color-accent-green) 30%, transparent);
  }
  .category-pill[data-category="embedded"] {
    background-color: color-mix(in srgb, var(--color-accent-warm) 20%, transparent);
    color: var(--color-accent-warm);
    border-color: color-mix(in srgb, var(--color-accent-warm) 30%, transparent);
  }
  .category-pill[data-category="computer-vision"] {
    background-color: color-mix(in srgb, var(--color-accent) 20%, transparent);
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }
  .category-pill[data-category="web"] {
    background-color: color-mix(in srgb, var(--color-accent) 20%, transparent);
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }
</style>
